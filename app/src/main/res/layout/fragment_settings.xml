<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- APP SETTINGS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="APPLICATION"
            android:textColor="#80A88F"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0B110D"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Phone Alerts Toggle -->
                <LinearLayout
                    android:id="@+id/row_phone_alerts"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phone Alerts"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vibrate/Notify when ready"
                            android:textColor="#80A88F"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_phone_alerts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="#141E17" />

                <!-- Day Start Hour -->
                <LinearLayout
                    android:id="@+id/row_day_start_hour"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Day Start Hour"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/tv_day_start_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Day view begins at 4 AM"
                            android:textColor="#80A88F"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tv_day_start_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4 AM"
                        android:textColor="#00FF41"
                        android:textSize="16sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="#141E17" />

                <!-- Data Retention -->
                <LinearLayout
                    android:id="@+id/row_retention_days"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Data Retention"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Keep history for this many days"
                            android:textColor="#80A88F"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tv_retention_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="90 days"
                        android:textColor="#00FF41"
                        android:textSize="16sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- APP FEATURES -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="APP FEATURES"
            android:textColor="#80A88F"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0B110D"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Dim LED While Charging -->
                <LinearLayout
                    android:id="@+id/row_dim_on_charge"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dim LED While Charging"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Set LED to minimum, restore after"
                            android:textColor="#80A88F"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_dim_on_charge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ALERTS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="ALERTS"
            android:textColor="#80A88F"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0B110D"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Alert: Temp Ready -->
                <LinearLayout
                    android:id="@+id/row_alert_temp_ready"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Temperature Ready"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notify when device reaches target temp"
                            android:textColor="#80A88F"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_alert_temp_ready"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="#141E17" />

                <!-- Alert: Charge 80% -->
                <LinearLayout
                    android:id="@+id/row_alert_charge_80"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Charge 80%"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notify when battery reaches 80% while charging"
                            android:textColor="#80A88F"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_alert_charge_80"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="#141E17" />

                <!-- Alert: Session End -->
                <LinearLayout
                    android:id="@+id/row_alert_session_end"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Session End"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notify when heater turns off after a session"
                            android:textColor="#80A88F"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_alert_session_end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- TOLERANCE BREAK -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="TOLERANCE BREAK"
            android:textColor="#80A88F"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0B110D"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Break Goal row -->
                <LinearLayout
                    android:id="@+id/row_break_goal"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Break Goal"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Target days without a session"
                            android:textColor="#80A88F"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_break_goal_days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7 days"
                        android:textColor="#30D158"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- TEMPERATURE PRESETS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="TEMPERATURE PRESETS"
            android:textColor="#80A88F"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0B110D"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:id="@+id/ll_preset_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <LinearLayout
                    android:id="@+id/row_add_preset"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Add Preset"
                        android:textColor="#30D158"
                        android:textSize="15sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+"
                        android:textColor="#30D158"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- DEVICE CONTROLS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="GENERAL"
            android:textColor="#80A88F"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0B110D"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Unit Toggle -->
                <LinearLayout
                    android:id="@+id/row_unit"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Temperature Unit"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_unit_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="°C"
                        android:textColor="#00FF41"
                        android:textSize="16sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="#141E17" />

                <!-- Auto Shutdown -->
                <LinearLayout
                    android:id="@+id/row_auto_shutdown"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Auto Shutdown"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_auto_shutdown_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--m"
                        android:textColor="#00FF41"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- DISPLAY & HAPTICS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="DISPLAY &amp; VIBRATION"
            android:textColor="#80A88F"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0B110D"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Vibration Toggle (CMD_BRIGHTNESS_VIBRATION byte 5 — actual haptic motor) -->
                <LinearLayout
                    android:id="@+id/row_vibration"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Device Vibration"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Haptic feedback on device"
                            android:textColor="#80A88F"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_vibration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="#141E17" />

                <!-- Boost Visualization (CMD_STATUS bit 0x40 — LED pulse during boost/superboost) -->
                <LinearLayout
                    android:id="@+id/row_boost_viz"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Boost Visualization"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LED pulse during boost/superboost"
                            android:textColor="#80A88F"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_boost_viz"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="#141E17" />

                <!-- Brightness Slider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LED Brightness"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                    <SeekBar
                        android:id="@+id/seek_brightness"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:max="8"
                        android:progress="4"
                        android:splitTrack="false"
                        android:thumbTint="#00FF41"
                        android:progressTint="#00FF41" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CHARGING & BATTERY -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="CHARGING &amp; BATTERY"
            android:textColor="#80A88F"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0B110D"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Charge Opt -->
                <LinearLayout
                    android:id="@+id/row_charge_opt"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Eco Charge (Current)"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_charge_opt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="#141E17" />

                <!-- Charge Limit -->
                <LinearLayout
                    android:id="@+id/row_charge_limit"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Safe Charge (Voltage)"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_charge_limit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ADVANCED -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="ADVANCED"
            android:textColor="#80A88F"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0B110D"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Permanent BLE -->
                <LinearLayout
                    android:id="@+id/row_perm_ble"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Permanent Bluetooth"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_perm_ble"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="#141E17" />

                <!-- Boost Timeout Toggle -->
                <LinearLayout
                    android:id="@+id/row_boost_timeout"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Boost Timeout"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_boost_timeout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Device Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="HARDWARE INFO"
            android:textColor="#80A88F"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0B110D"
            app:cardCornerRadius="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView android:id="@+id/tv_settings_model" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Model: ---" android:textColor="#FFFFFF" android:textSize="14sp" />
                <TextView android:id="@+id/tv_settings_serial" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Serial: ---" android:textColor="#80A88F" android:textSize="13sp" />
                <TextView android:id="@+id/tv_settings_mac" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Address: ---" android:textColor="#80A88F" android:textSize="13sp" />
                <TextView android:id="@+id/tv_settings_firmware" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Firmware: ---" android:textColor="#80A88F" android:textSize="13sp" />
                <TextView android:id="@+id/tv_settings_color" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Color Index: ---" android:textColor="#80A88F" android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_find_device"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#141E17"
            android:text="FIND DEVICE (Vibrate)"
            android:textColor="#00FF41"
            app:cornerRadius="16dp" />

        <Button
            android:id="@+id/btn_factory_reset"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#141E17"
            android:text="FACTORY RESET DEVICE"
            android:textColor="#FF453A"
            app:cornerRadius="16dp" />

        <Button
            android:id="@+id/btn_clear_device_history"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#141E17"
            android:text="CLEAR DEVICE HISTORY"
            android:textColor="#FF453A"
            app:cornerRadius="16dp" />

        <Button
            android:id="@+id/btn_backup_database"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#141E17"
            android:text="BACKUP DATABASE"
            android:textColor="#00FF41"
            app:cornerRadius="16dp" />

        <Button
            android:id="@+id/btn_restore_database"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#141E17"
            android:text="RESTORE DATABASE"
            android:textColor="#0A84FF"
            app:cornerRadius="16dp" />

        <!-- ── DEVELOPER TOOLS (hidden — tap firmware version 7× to unlock) ── -->
        <LinearLayout
            android:id="@+id/layout_dev_tools"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="DEVELOPER"
                android:textColor="#80A88F"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_dev_rebuild_history"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#141E17"
                android:text="DEV: REBUILD HISTORY FROM LOGS"
                android:textColor="#30D158"
                app:cornerRadius="16dp" />

            <Button
                android:id="@+id/btn_dev_inject_test_device"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#0B110D"
                android:text="DEV: INJECT TEST DEVICE"
                android:textColor="#0A84FF"
                app:cornerRadius="16dp" />

            <Button
                android:id="@+id/btn_dev_remove_test_device"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#0B110D"
                android:text="DEV: REMOVE TEST DEVICE"
                android:textColor="#FF453A"
                app:cornerRadius="16dp" />

        </LinearLayout>


        <!-- HEALTH & DOSAGE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="HEALTH &amp; DOSAGE"
            android:textColor="#80A88F"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0B110D"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Default Pack Type row -->
                <LinearLayout
                    android:id="@+id/row_default_pack_type"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Default Pack Type"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_default_pack_type_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Free Pack"
                        android:textColor="#00FF41"
                        android:textSize="16sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="#141E17" />

                <!-- Capsule Weight row -->
                <LinearLayout
                    android:id="@+id/row_capsule_weight"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?android:attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Capsule Weight"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_capsule_weight_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.10 g"
                        android:textColor="#00FF41"
                        android:textSize="16sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
