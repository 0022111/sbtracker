<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_dashboard_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <TextView
        android:id="@+id/tv_step_num"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="#80A88F"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_step_temp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@null"
        android:gravity="center"
        android:hint="Temp"
        android:inputType="number"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="°C"
        android:textColor="#80A88F"
        android:textSize="12sp" />

    <View
        android:layout_width="1dp"
        android:layout_height="24dp"
        android:layout_marginHorizontal="12dp"
        android:background="#3A3A3C" />

    <EditText
        android:id="@+id/et_step_duration"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@null"
        android:gravity="center"
        android:hint="Time"
        android:inputType="number"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="sec"
        android:textColor="#80A88F"
        android:textSize="12sp" />

    <ImageButton
        android:id="@+id/btn_remove_step"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="#FF453A" />

</LinearLayout>
