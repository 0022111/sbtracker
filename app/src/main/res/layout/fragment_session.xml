<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_session_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Session"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/session_content_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_session_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:id="@+id/card_big_temp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#1C1C1E"
                app:cardCornerRadius="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <TextView
                        android:id="@+id/session_tv_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="---°"
                        android:textColor="#FFFFFF"
                        android:textSize="64sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/session_tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="OFFLINE"
                        android:textColor="#8E8E93"
                        android:textSize="14sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <!-- Hits + Timer + Drain row (only visible when running) -->
                    <LinearLayout
                        android:id="@+id/session_running_stats_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/session_tv_hits"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFD60A"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="HITS"
                                android:textColor="#8E8E93"
                                android:textSize="10sp"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="#3A3A3C" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/session_tv_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00:00"
                                android:textColor="#FFFFFF"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ELAPSED"
                                android:textColor="#8E8E93"
                                android:textSize="10sp"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="#3A3A3C" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/session_tv_drain"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="#FF453A"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DRAIN"
                                android:textColor="#8E8E93"
                                android:textSize="10sp"
                                android:letterSpacing="0.05" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Active Hit / Breath Tracking -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_active_hit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#0A84FF"
                app:cardCornerRadius="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ACTIVE BREATH"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_hit_timer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0s"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Mode Selection Buttons -->
            <LinearLayout
                android:id="@+id/mode_selection_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_mode_normal"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#2C2C2E"
                    android:text="NORMAL"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />

                <Button
                    android:id="@+id/btn_mode_boost"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#2C2C2E"
                    android:text="BOOST"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />

                <Button
                    android:id="@+id/btn_mode_superboost"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#2C2C2E"
                    android:text="SUPER"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- Controls (ALWAYS VISIBLE IF CONNECTED) -->
            <LinearLayout
                android:id="@+id/session_controls_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <!-- Base Temp -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="BASE TEMP"
                        android:textColor="#8E8E93"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <ImageButton
                        android:id="@+id/btn_temp_minus"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_input_delete"
                        app:tint="#0A84FF" />
                    <TextView
                        android:id="@+id/tv_target_temp"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="180°"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <ImageButton
                        android:id="@+id/btn_temp_plus"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_input_add"
                        app:tint="#0A84FF" />
                </LinearLayout>

                <!-- Boost Group -->
                <LinearLayout
                    android:id="@+id/group_boost_controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- Boost -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="BOOST"
                            android:textColor="#8E8E93"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <ImageButton
                            android:id="@+id/btn_boost_minus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_input_delete"
                            app:tint="#FFD60A" />
                        <TextView
                            android:id="@+id/tv_boost_offset"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="+10°"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <ImageButton
                            android:id="@+id/btn_boost_plus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_input_add"
                            app:tint="#FFD60A" />
                    </LinearLayout>

                    <!-- Super Boost -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="SUPER BOOST"
                            android:textColor="#8E8E93"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <ImageButton
                            android:id="@+id/btn_superboost_minus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_input_delete"
                            app:tint="#FF9F0A" />
                        <TextView
                            android:id="@+id/tv_superboost_offset"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="+20°"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <ImageButton
                            android:id="@+id/btn_superboost_plus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_input_add"
                            app:tint="#FF9F0A" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Stats Grid (only when running) -->
            <GridLayout
                android:id="@+id/stats_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="3"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_dashboard_card"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HEAT-UP" android:textColor="#8E8E93" android:textSize="10sp" />
                    <TextView android:id="@+id/session_tv_heat_up" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#FFD60A" android:textSize="18sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_dashboard_card"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginHorizontal="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="READY" android:textColor="#8E8E93" android:textSize="10sp" />
                    <TextView android:id="@+id/session_tv_ready_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00" android:textColor="#30D158" android:textSize="18sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_dashboard_card"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginStart="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BATTERY" android:textColor="#8E8E93" android:textSize="10sp" />
                    <TextView android:id="@+id/session_tv_battery" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--%" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
                </LinearLayout>
            </GridLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_start_normal"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:backgroundTint="#30D158"
                    android:text="BEGIN SESSION"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:cornerRadius="20dp" />

                <Button
                    android:id="@+id/btn_end_session"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:backgroundTint="#FF453A"
                    android:text="END SESSION"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:cornerRadius="20dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
