<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_session_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Command Center"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/session_content_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_session_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HERO CARD (Dynamic Status) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_big_temp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#0B110D"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <TextView
                        android:id="@+id/session_tv_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="---°"
                        android:textColor="#FFFFFF"
                        android:textSize="72sp"
                        android:fontFamily="sans-serif-black" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/session_tv_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OFFLINE"
                            android:textColor="#80A88F"
                            android:textSize="16sp"
                            android:letterSpacing="0.15"
                            android:textStyle="bold" />
                    </LinearLayout>
                    
                    <TextView
                        android:id="@+id/session_tv_next_stage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Next stage in: 00:00"
                        android:textColor="#00FF41"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <!-- Running Stats Row -->
                    <LinearLayout
                        android:id="@+id/session_running_stats_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/session_tv_hits"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#00FF41"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="HITS"
                                android:textColor="#80A88F"
                                android:textSize="10sp"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="#3A3A3C" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/session_tv_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00:00"
                                android:textColor="#FFFFFF"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ELAPSED"
                                android:textColor="#80A88F"
                                android:textSize="10sp"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="#3A3A3C" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/session_tv_drain"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="#FF453A"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DRAIN"
                                android:textColor="#80A88F"
                                android:textSize="10sp"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/session_tv_starting_battery"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="START: --%"
                                android:textColor="#80FFFFFF"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- PRE-IGNITE PREVIEW (F-027 Polish) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_program_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#091F0D"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRE-FLIGHT PREVIEW"
                        android:textColor="#80A88F"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/session_tv_heat_up_estimate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Est. ready in --s"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/session_tv_drain_preview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Est. drain: --%"
                        android:textColor="#80A88F"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Active Hit Notification -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_active_hit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#00FF41"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingVertical="16dp"
                    android:paddingHorizontal="24dp">
                    
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_popup_sync"
                        app:tint="#FFFFFF"
                        android:layout_marginEnd="12dp" />
                        
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ACTIVE BREATH"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:letterSpacing="0.05"
                        android:textStyle="bold" />
                        
                    <TextView
                        android:id="@+id/tv_hit_timer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0s"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Action Buttons -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <Button
                    android:id="@+id/btn_start_normal"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:backgroundTint="#30D158"
                    android:text="IGNITE"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-black"
                    app:cornerRadius="24dp" />

                <Button
                    android:id="@+id/btn_end_session"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:backgroundTint="#FF453A"
                    android:text="POWER OFF"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-black"
                    android:visibility="gone"
                    app:cornerRadius="24dp" />
            </FrameLayout>

            <!-- Stats Grid -->
            <GridLayout
                android:id="@+id/stats_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="3"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_dashboard_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HEAT-UP" android:textColor="#80A88F" android:textSize="10sp" android:letterSpacing="0.05"/>
                    <TextView android:id="@+id/session_tv_heat_up" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="—" android:textColor="#FFD60A" android:textSize="20sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_dashboard_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginHorizontal="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="READY" android:textColor="#80A88F" android:textSize="10sp" android:letterSpacing="0.05"/>
                    <TextView android:id="@+id/session_tv_ready_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="00:00" android:textColor="#30D158" android:textSize="20sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_dashboard_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BATTERY" android:textColor="#80A88F" android:textSize="10sp" android:letterSpacing="0.05"/>
                    <TextView android:id="@+id/session_tv_battery" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="--%" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" />
                </LinearLayout>
            </GridLayout>

            <!-- Mode Controls Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="OPERATING MODE"
                android:textColor="#80A88F"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <!-- Mode Selection Buttons -->
            <LinearLayout
                android:id="@+id/mode_selection_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_mode_normal"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="#141E17"
                    android:text="NORMAL"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/btn_mode_boost"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginHorizontal="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="#141E17"
                    android:text="BOOST"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/btn_mode_superboost"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="#141E17"
                    android:text="SUPER"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />
            </LinearLayout>

            <!-- Parameter Controls Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#0B110D"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:id="@+id/session_controls_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <!-- Base Temp -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TARGET TEMP"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Normal operating temperature"
                                android:textColor="#80A88F"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_dashboard_card"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="4dp">
                            
                            <ImageButton
                                android:id="@+id/btn_temp_minus"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_media_previous"
                                android:rotation="-90"
                                app:tint="#00FF41" />
                            <TextView
                                android:id="@+id/tv_target_temp"
                                android:layout_width="64dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="180°"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-medium" />
                            <ImageButton
                                android:id="@+id/btn_temp_plus"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_media_next"
                                android:rotation="-90"
                                app:tint="#00FF41" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Temp Preset Chips -->
                    <HorizontalScrollView
                        android:id="@+id/hsv_temp_presets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:scrollbars="none">
                        <LinearLayout
                            android:id="@+id/ll_temp_preset_chips"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical" />
                    </HorizontalScrollView>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#141E17"
                        android:layout_marginHorizontal="16dp" />

                    <!-- Boost Group -->
                    <LinearLayout
                        android:id="@+id/group_boost_controls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <!-- Boost -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp">
                            
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="BOOST OFFSET"
                                    android:textColor="#FFFFFF"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Temperature delta"
                                    android:textColor="#80A88F"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:background="@drawable/bg_dashboard_card"
                                android:paddingHorizontal="4dp"
                                android:paddingVertical="4dp">
                                <ImageButton
                                    android:id="@+id/btn_boost_minus"
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:src="@android:drawable/ic_media_previous"
                                    android:rotation="-90"
                                    app:tint="#FFD60A" />
                                <TextView
                                    android:id="@+id/tv_boost_offset"
                                    android:layout_width="64dp"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="+10°"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp"
                                    android:fontFamily="sans-serif-medium" />
                                <ImageButton
                                    android:id="@+id/btn_boost_plus"
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:src="@android:drawable/ic_media_next"
                                    android:rotation="-90"
                                    app:tint="#FFD60A" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#141E17"
                            android:layout_marginHorizontal="16dp" />

                        <!-- Super Boost -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp">
                            
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="SUPER OFFSET"
                                    android:textColor="#FFFFFF"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Maximum heating delta"
                                    android:textColor="#80A88F"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:background="@drawable/bg_dashboard_card"
                                android:paddingHorizontal="4dp"
                                android:paddingVertical="4dp">
                                <ImageButton
                                    android:id="@+id/btn_superboost_minus"
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:src="@android:drawable/ic_media_previous"
                                    android:rotation="-90"
                                    app:tint="#FF9F0A" />
                                <TextView
                                    android:id="@+id/tv_superboost_offset"
                                    android:layout_width="64dp"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="+20°"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp"
                                    android:fontFamily="sans-serif-medium" />
                                <ImageButton
                                    android:id="@+id/btn_superboost_plus"
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:src="@android:drawable/ic_media_next"
                                    android:rotation="-90"
                                    app:tint="#FF9F0A" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
