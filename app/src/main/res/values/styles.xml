<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose-only app: any NoActionBar base is fine. Using the platform
         theme avoids pulling in appcompat or the material component library;
         Compose supplies all real styling via SBTrackerTheme. -->
    <style name="Theme.SBTracker" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>
</resources>
